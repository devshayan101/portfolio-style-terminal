{
  "enableAllProjectMcpServers": true,
  "enabledMcpServers": [
    "sequential-thinking",
    "local-file-system"
  ],
  "mcp": {
    "servers": {
      "sequential-thinking": {
        "command": "cmd",
        "args": [
          "/c",
          "npx",
          "-y",
          "@modelcontextprotocol/server-sequential-thinking"
        ]
      },
      "local-file-system": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-local-file-system"
        ]
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(git add *)"
    ]
  }
}
